// ОСЦИЛЛОГРАФ ДЛЯ ЭНКОДЕРОВ
const int ENC_RIGHT = 2;
const int ENC_LEFT = 3;

void setup() {
  Serial.begin(115200);
  Serial.println("Осциллограф энкодеров");
  Serial.println("Формат: Right,Left");
  
  pinMode(ENC_RIGHT, INPUT_PULLUP);
  pinMode(ENC_LEFT, INPUT_PULLUP);
}

void loop() {
  Serial.print(digitalRead(ENC_RIGHT));
  Serial.print(",");
  Serial.println(digitalRead(ENC_LEFT));
  delay(10); // 100 раз в секунду
}
