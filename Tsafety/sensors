// Пины, к которым подключены датчики
const int leftSensorPin = A9;   // Левый датчик
const int rightSensorPin = A10; // Правый датчик

void setup() {
  // Запускаем Serial-порт для вывода данных в монитор
  Serial.begin(115200);  // Скорость должна совпадать со скоростью в мониторе порта
                         // Обычно используют 9600 или 115200, проверь.
}

void loop() {

  int leftValue = analogRead(leftSensorPin);
  int rightValue = analogRead(rightSensorPin);
  

  Serial.print("Left sensor (A9): ");
  Serial.print(leftValue);
  Serial.print(" | Right sensor (A10): ");
  Serial.println(rightValue);
  
  // Небольшая задержка для стабильности
  delay(100);
}
